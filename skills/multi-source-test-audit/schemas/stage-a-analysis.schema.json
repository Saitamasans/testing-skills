{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage-a-analysis-v2",
  "type": "object",
  "required": ["schema_version", "project", "materials", "capability", "profile", "associations", "behavior_differences", "candidates", "later_stage_recommendations"],
  "properties": {
    "schema_version": {"const": "stage-a-analysis-v2"},
    "project": {"type": "object", "required": ["id", "name"], "properties": {"id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "materials": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["material_id", "path", "role"], "properties": {"material_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "role": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
    "capability": {"type": "object", "required": ["level", "explanation"], "properties": {"level": {"enum": ["M1", "M2", "M3", "M4"]}, "explanation": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "profile": {"type": "array", "minItems": 9, "items": {"allOf": [{"$ref": "#/$defs/scoped"}, {"type": "object", "required": ["fact_id", "dimension", "statement", "basis_status", "source_locations"], "properties": {"fact_id": {"type": "string", "minLength": 1}, "dimension": {"enum": ["actor", "resource", "action", "input", "state", "permission", "trust_boundary", "side_effect", "evidence_source"]}, "statement": {"type": "string", "minLength": 1}, "basis_status": {"$ref": "#/$defs/basisStatus"}, "source_locations": {"$ref": "#/$defs/textList"}}}] }},
    "associations": {"type": "array", "minItems": 1, "items": {"allOf": [{"$ref": "#/$defs/scoped"}, {"type": "object", "required": ["association_id", "action", "requirement", "caller", "interface", "backend", "side_effect", "source_locations", "basis_status", "behavior_difference"], "properties": {"association_id": {"type": "string", "minLength": 1}, "action": {"type": "string", "minLength": 1}, "requirement": {"type": "string", "minLength": 1}, "caller": {"type": "string", "minLength": 1}, "interface": {"type": "string", "minLength": 1}, "backend": {"type": "string", "minLength": 1}, "side_effect": {"type": "string", "minLength": 1}, "source_locations": {"$ref": "#/$defs/textList"}, "basis_status": {"$ref": "#/$defs/basisStatus"}, "behavior_difference": {"type": "string"}}}] }},
    "behavior_differences": {"type": "array", "items": {"type": "object", "required": ["summary", "source_locations"], "properties": {"summary": {"type": "string", "minLength": 1}, "source_locations": {"$ref": "#/$defs/textList"}}, "additionalProperties": false}},
    "candidates": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/candidate"}},
    "later_stage_recommendations": {"$ref": "#/$defs/textList"}
  },
  "$defs": {
    "textList": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "basisStatus": {"enum": ["confirmed_fact", "audit_inference", "unknown_rule", "user_confirmed_rule"]},
    "scoped": {"type": "object", "required": ["scope", "chain_id"], "properties": {"scope": {"enum": ["global", "selected_chain"]}, "chain_id": {"type": ["string", "null"]}}},
    "componentRole": {"enum": ["client", "backend", "admin_console", "web", "mobile", "desktop", "service", "data_store", "cache", "queue", "scheduled_job", "external_service", "interface_document", "requirement_document", "other"]},
    "component": {"type": "object", "required": ["component_id", "component_role", "component_name", "technology", "material_id", "file_path", "symbol", "line_range", "relevance", "provenance"], "properties": {"component_id": {"type": "string", "minLength": 1}, "component_role": {"$ref": "#/$defs/componentRole"}, "component_name": {"type": "string", "minLength": 1}, "technology": {"type": "string", "minLength": 1}, "material_id": {"type": "string", "minLength": 1}, "file_path": {"type": "string", "minLength": 1}, "symbol": {"type": ["string", "null"]}, "line_range": {"type": ["string", "null"]}, "relevance": {"type": "string", "minLength": 1}, "provenance": {"$ref": "#/$defs/basisStatus"}}, "additionalProperties": false},
    "interface": {"type": "object", "required": ["interface_id", "chain_id", "method", "path", "interface_name", "group", "source", "relevance", "provenance"], "properties": {"interface_id": {"type": "string", "minLength": 1}, "chain_id": {"type": "string", "minLength": 1}, "method": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "interface_name": {"type": "string", "minLength": 1}, "group": {"type": "string", "minLength": 1}, "source": {"type": "string", "minLength": 1}, "relevance": {"type": "string", "minLength": 1}, "provenance": {"$ref": "#/$defs/basisStatus"}}, "additionalProperties": false},
    "clue": {"allOf": [{"$ref": "#/$defs/scoped"}, {"type": "object", "required": ["clue_id", "category", "summary", "root_cause", "score", "source_locations", "black_box_steps", "proposed_role", "mutation_parameters", "side_effect_check", "risk", "stage_b_approval"], "properties": {"clue_id": {"type": "string", "minLength": 1}, "category": {"enum": ["audit_clue", "behavior_difference", "pending_validation_risk", "rule_pending_confirmation"]}, "summary": {"type": "string", "minLength": 1}, "root_cause": {"type": "string", "minLength": 1}, "score": {"type": "number", "minimum": 0, "maximum": 100}, "source_locations": {"$ref": "#/$defs/textList"}, "black_box_steps": {"$ref": "#/$defs/textList"}, "proposed_role": {"type": "string", "minLength": 1}, "mutation_parameters": {"$ref": "#/$defs/textList"}, "side_effect_check": {"type": "string", "minLength": 1}, "risk": {"type": "string", "minLength": 1}, "stage_b_approval": {"type": "string", "minLength": 1}}}]},
    "candidate": {"type": "object", "required": ["chain_id", "name", "recommendation_reason", "conditions", "gaps", "risks", "materials", "clues", "business_entry", "component_references", "interface_references", "priority_reason", "estimated_interface_count", "source_coverage"], "properties": {"chain_id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}, "recommendation_reason": {"type": "string", "minLength": 1}, "conditions": {"$ref": "#/$defs/textList"}, "gaps": {"$ref": "#/$defs/textList"}, "risks": {"$ref": "#/$defs/textList"}, "materials": {"$ref": "#/$defs/textList"}, "clues": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/clue"}}, "business_entry": {"type": "object", "required": ["name", "component", "source", "relevance"], "properties": {"name": {"type": "string", "minLength": 1}, "component": {"type": "string", "minLength": 1}, "source": {"type": "string", "minLength": 1}, "relevance": {"type": "string", "minLength": 1}}, "additionalProperties": false}, "component_references": {"type": "array", "items": {"$ref": "#/$defs/component"}}, "interface_references": {"type": "array", "items": {"$ref": "#/$defs/interface"}}, "priority_reason": {"type": "object", "required": ["why_priority", "risk_value", "material_completeness", "later_verifiability", "later_execution_safety"], "properties": {"why_priority": {"type": "string", "minLength": 1}, "risk_value": {"type": "string", "minLength": 1}, "material_completeness": {"type": "string", "minLength": 1}, "later_verifiability": {"type": "string", "minLength": 1}, "later_execution_safety": {"type": "string", "minLength": 1}}, "additionalProperties": false}, "estimated_interface_count": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "object"}]}, "source_coverage": {"type": "array", "items": {"type": "object", "required": ["component_role", "status"], "properties": {"component_role": {"$ref": "#/$defs/componentRole"}, "status": {"enum": ["linked", "missing", "not_applicable", "not_located"]}}, "additionalProperties": false}}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
