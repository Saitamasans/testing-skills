{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "selected-chain-plan-v1",
  "type": "object",
  "required": ["schema_version", "project_id", "selected_chain_id", "selected_chain_name", "candidate_set_hash", "material_inventory_hash", "selected_chain_summary", "selected_chain_unknown_rules", "selected_chain_associations", "selected_chain_clues", "audit_plan_items", "generated_context", "provenance"],
  "properties": {
    "schema_version": {"const": "selected-chain-plan-v1"},
    "project_id": {"type": "string", "minLength": 1},
    "selected_chain_id": {"type": "string", "minLength": 1},
    "selected_chain_name": {"type": "string", "minLength": 1},
    "candidate_set_hash": {"type": "string", "minLength": 1},
    "material_inventory_hash": {"type": "string", "minLength": 1},
    "selected_chain_summary": {"type": "string", "minLength": 1},
    "selected_chain_unknown_rules": {"$ref": "#/$defs/textList"},
    "selected_chain_associations": {"$ref": "#/$defs/textList"},
    "selected_chain_clues": {"$ref": "#/$defs/textList"},
    "audit_plan_items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/planItem"}},
    "generated_context": {"type": "object"},
    "provenance": {"type": "object"}
  },
  "$defs": {
    "textList": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "reference": {"type": "object", "required": ["reference_type", "reference_id"], "properties": {"reference_type": {"enum": ["material_id", "fact_id", "association_id", "clue_id", "interface_id"]}, "reference_id": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "planItem": {"type": "object", "required": ["plan_id", "title", "category", "semantic_source", "basis_references", "expected_basis", "preconditions", "steps", "expected_result", "roles", "mutation_parameters", "side_effect_evidence", "risk", "current_status", "stage_b_approval", "notes"], "properties": {"plan_id": {"type": "string", "minLength": 1}, "title": {"type": "string", "minLength": 1}, "category": {"type": "string", "minLength": 1}, "semantic_source": {"enum": ["material_fact", "cross_source_inference", "generic_test_heuristic", "user_confirmed_rule", "unknown_rule"]}, "basis_references": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/reference"}}, "expected_basis": {"type": "string", "minLength": 1}, "preconditions": {"$ref": "#/$defs/textList"}, "steps": {"$ref": "#/$defs/textList"}, "expected_result": {"type": "string", "minLength": 1}, "roles": {"$ref": "#/$defs/textList"}, "mutation_parameters": {"$ref": "#/$defs/textList"}, "side_effect_evidence": {"$ref": "#/$defs/textList"}, "risk": {"type": "string", "minLength": 1}, "current_status": {"const": "not_executed"}, "stage_b_approval": {"type": "string", "minLength": 1}, "notes": {"type": "string", "minLength": 1}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
