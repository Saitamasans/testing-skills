{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Testing Skills 双格式报告",
  "type": "object",
  "required": ["title", "generated_at", "skill_invocation", "sheets"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "project": {"type": "string"},
    "generated_at": {"type": "string"},
    "skill_invocation": {
      "oneOf": [
        {"type": "string"},
        {
          "type": "object",
          "required": ["primary"],
          "properties": {
            "primary": {"type": "string"},
            "secondary": {"type": "string"},
            "roles": {"type": "string"},
            "confirmation": {"type": "string"}
          }
        }
      ]
    },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind", "columns", "rows"],
        "properties": {
          "name": {"type": "string"},
          "kind": {"enum": ["overview", "test_cases", "supplementary"]},
          "columns": {"type": "array", "items": {"type": "string"}},
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["values"],
              "properties": {
                "divider": {"type": "boolean"},
                "values": {"type": "array"}
              }
            }
          }
        }
      }
    }
  }
}
