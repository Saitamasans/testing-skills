{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saitamasans.dev/schemas/run-manifest.schema.json",
  "title": "Run manifest protocol 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "manifest_id", "runner", "source", "cases"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "manifest_id": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": { "version": { "const": "1.0.0" } }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/nonSecretText" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "targets": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/safeHttpUrl" } },
    "rule_versions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/manifestCase" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "risk": { "enum": ["R0", "R1", "R2", "R3"] },
    "safeHttpUrl": {
      "type": "string",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://[^\\s]+$"
    },
    "relativePath": {
      "allOf": [
        { "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" },
        { "type": "string", "pattern": "^/(?!/)[^\\s?#]*$" }
      ]
    },
    "dataReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "name"],
      "properties": {
        "source": { "enum": ["env", "fixture", "output"] },
        "name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" }
      }
    },
    "referenceMap": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
      "additionalProperties": { "$ref": "#/$defs/dataReference" }
    },
    "nonSecretText": { "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" },
    "original": {
      "type": "object",
      "additionalProperties": false,
      "required": ["用例 ID", "所属模块", "用例标题", "验证功能点", "前置条件", "测试步骤", "预期结果", "优先级", "执行结果", "备注"],
      "properties": {
        "用例 ID": { "$ref": "#/$defs/nonSecretText" },
        "所属模块": { "$ref": "#/$defs/nonSecretText" },
        "用例标题": { "$ref": "#/$defs/nonSecretText" },
        "验证功能点": { "$ref": "#/$defs/nonSecretText" },
        "前置条件": { "$ref": "#/$defs/nonSecretText" },
        "测试步骤": { "$ref": "#/$defs/nonSecretText" },
        "预期结果": { "$ref": "#/$defs/nonSecretText" },
        "优先级": { "$ref": "#/$defs/nonSecretText" },
        "执行结果": { "allOf": [{ "$ref": "#/$defs/nonSecretText" }, { "enum": ["", "未执行", "通过", "不通过", "待定"] }] },
        "备注": { "$ref": "#/$defs/nonSecretText" }
      }
    },
    "actionBase": {
      "type": "object",
      "required": ["type", "action_id", "target_alias", "risk"],
      "properties": {
        "type": { "type": "string" },
        "action_id": { "allOf": [{ "$ref": "#/$defs/nonSecretText" }, { "type": "string", "minLength": 1 }] },
        "target_alias": { "allOf": [{ "$ref": "#/$defs/nonSecretText" }, { "type": "string", "minLength": 1 }] },
        "risk": { "$ref": "#/$defs/risk" },
        "source_step": { "$ref": "#/$defs/nonSecretText" },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "retry_eligible": { "type": "boolean" }
      }
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/webGoto" },
        { "$ref": "#/$defs/webFill" },
        { "$ref": "#/$defs/webClick" },
        { "$ref": "#/$defs/webSelect" },
        { "$ref": "#/$defs/webWait" },
        { "$ref": "#/$defs/webAssert" },
        { "$ref": "#/$defs/apiRequest" },
        { "$ref": "#/$defs/apiConcurrent" },
        { "$ref": "#/$defs/apiExtract" },
        { "$ref": "#/$defs/apiAssert" },
        { "$ref": "#/$defs/executionBlocked" },
        { "$ref": "#/$defs/dbSelect" },
        { "$ref": "#/$defs/dbAssert" },
        { "$ref": "#/$defs/cleanupApi" },
        { "$ref": "#/$defs/cleanupWeb" }
      ]
    },
    "webGoto": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["url"],
      "properties": { "type": { "const": "web.goto" }, "url": { "$ref": "#/$defs/safeHttpUrl" } }
    },
    "webFill": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator", "value_ref"],
      "properties": { "type": { "const": "web.fill" }, "locator": { "$ref": "#/$defs/nonSecretText" }, "value_ref": { "$ref": "#/$defs/dataReference" } }
    },
    "webClick": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator"],
      "properties": {
        "type": { "const": "web.click" },
        "locator": { "$ref": "#/$defs/nonSecretText" },
        "click_count": { "const": 2 }
      }
    },
    "webSelect": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator", "option"],
      "properties": { "type": { "const": "web.select" }, "locator": { "$ref": "#/$defs/nonSecretText" }, "option": { "$ref": "#/$defs/nonSecretText" } }
    },
    "webWait": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["condition"],
      "properties": { "type": { "const": "web.wait" }, "condition": { "$ref": "#/$defs/nonSecretText" } }
    },
    "webAssert": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["assertion"],
      "properties": { "type": { "const": "web.assert" }, "assertion": { "$ref": "#/$defs/nonSecretText" } }
    },
    "apiRequest": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["method", "path"],
      "properties": {
        "type": { "const": "api.request" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "$ref": "#/$defs/relativePath" },
        "input_ref": { "$ref": "#/$defs/dataReference" },
        "raw_body_ref": { "$ref": "#/$defs/dataReference" },
        "header_refs": { "$ref": "#/$defs/referenceMap" },
        "query_refs": { "$ref": "#/$defs/referenceMap" },
        "json_body_refs": { "$ref": "#/$defs/referenceMap" }
      }
    },
    "apiExtract": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["from", "as"],
      "properties": { "type": { "const": "api.extract" }, "from": { "$ref": "#/$defs/nonSecretText" }, "as": { "$ref": "#/$defs/nonSecretText" } }
    },
    "apiAssert": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["assertion"],
      "properties": {
        "type": { "const": "api.assert" },
        "assertion": { "$ref": "#/$defs/nonSecretText" },
        "verdict_policy": { "enum": ["auto", "pending_only"] },
        "root_cause_key": { "$ref": "#/$defs/nonSecretText" }
      }
    },
    "apiConcurrent": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["method", "path", "concurrency"],
      "properties": {
        "type": { "const": "api.concurrent" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "$ref": "#/$defs/relativePath" },
        "concurrency": { "type": "integer", "minimum": 2, "maximum": 20 },
        "input_ref": { "$ref": "#/$defs/dataReference" },
        "raw_body_ref": { "$ref": "#/$defs/dataReference" },
        "header_refs": { "$ref": "#/$defs/referenceMap" },
        "query_refs": { "$ref": "#/$defs/referenceMap" },
        "json_body_refs": { "$ref": "#/$defs/referenceMap" }
      }
    },
    "executionBlocked": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["reason"],
      "properties": {
        "type": { "const": "execution.blocked" },
        "reason": { "$ref": "#/$defs/nonSecretText" }
      }
    },
    "dbSelect": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["query"],
      "properties": {
        "type": { "const": "db.select" },
        "query": { "$ref": "#/$defs/nonSecretText" },
        "params_ref": { "$ref": "#/$defs/dataReference" },
        "limit": { "type": "integer", "minimum": 1 }
      }
    },
    "dbAssert": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["assertion"],
      "properties": {
        "type": { "const": "db.assert" },
        "assertion": { "$ref": "#/$defs/nonSecretText" }
      }
    },
    "cleanupApi": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["method", "path"],
      "properties": {
        "type": { "const": "cleanup.api" },
        "method": { "enum": ["POST", "PUT", "PATCH", "DELETE"] },
        "path": { "$ref": "#/$defs/relativePath" },
        "input_ref": { "$ref": "#/$defs/dataReference" }
      }
    },
    "cleanupWeb": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator"],
      "properties": { "type": { "const": "cleanup.web" }, "locator": { "$ref": "#/$defs/nonSecretText" } }
    },
    "manifestCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "original", "steps"],
      "properties": {
        "case_id": { "allOf": [{ "$ref": "#/$defs/nonSecretText" }, { "type": "string", "minLength": 1 }] },
        "original": { "$ref": "#/$defs/original" },
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/action" } }
      }
    }
  }
}
