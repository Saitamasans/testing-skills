{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saitamasans.dev/schemas/run-manifest.schema.json",
  "title": "Run manifest protocol 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "manifest_id", "runner", "source", "cases"],
  "properties": {
    "protocol_version": { "const": "1.0" },
    "manifest_id": { "type": "string", "minLength": 1 },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": { "version": { "type": "string", "minLength": 1 } }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/manifestCase" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "risk": { "enum": ["R0", "R1", "R2", "R3"] },
    "original": {
      "type": "object",
      "additionalProperties": false,
      "required": ["用例 ID", "所属模块", "用例标题", "验证功能点", "前置条件", "测试步骤", "预期结果", "优先级", "执行结果", "备注"],
      "properties": {
        "用例 ID": { "type": "string" },
        "所属模块": { "type": "string" },
        "用例标题": { "type": "string" },
        "验证功能点": { "type": "string" },
        "前置条件": { "type": "string" },
        "测试步骤": { "type": "string" },
        "预期结果": { "type": "string" },
        "优先级": { "type": "string" },
        "执行结果": { "enum": ["", "未执行", "通过", "不通过", "待定"] },
        "备注": { "type": "string" }
      }
    },
    "actionBase": {
      "type": "object",
      "required": ["type", "action_id", "target_alias", "risk"],
      "properties": {
        "type": { "type": "string" },
        "action_id": { "type": "string", "minLength": 1 },
        "target_alias": { "type": "string", "minLength": 1 },
        "risk": { "$ref": "#/$defs/risk" },
        "source_step": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "retry_eligible": { "type": "boolean" }
      }
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/webGoto" },
        { "$ref": "#/$defs/webFill" },
        { "$ref": "#/$defs/webClick" },
        { "$ref": "#/$defs/webSelect" },
        { "$ref": "#/$defs/webWait" },
        { "$ref": "#/$defs/webAssert" },
        { "$ref": "#/$defs/apiRequest" },
        { "$ref": "#/$defs/apiExtract" },
        { "$ref": "#/$defs/apiAssert" },
        { "$ref": "#/$defs/dbSelect" },
        { "$ref": "#/$defs/cleanupApi" },
        { "$ref": "#/$defs/cleanupWeb" }
      ]
    },
    "webGoto": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["url"],
      "properties": { "type": { "const": "web.goto" }, "url": { "type": "string" } }
    },
    "webFill": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator", "value_ref"],
      "properties": { "type": { "const": "web.fill" }, "locator": { "type": "string" }, "value_ref": { "type": "string" } }
    },
    "webClick": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator"],
      "properties": { "type": { "const": "web.click" }, "locator": { "type": "string" } }
    },
    "webSelect": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator", "option"],
      "properties": { "type": { "const": "web.select" }, "locator": { "type": "string" }, "option": { "type": "string" } }
    },
    "webWait": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["condition"],
      "properties": { "type": { "const": "web.wait" }, "condition": { "type": "string" } }
    },
    "webAssert": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["assertion"],
      "properties": { "type": { "const": "web.assert" }, "assertion": { "type": "string" } }
    },
    "apiRequest": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["method", "path"],
      "properties": {
        "type": { "const": "api.request" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string" },
        "input_ref": { "type": "string" }
      }
    },
    "apiExtract": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["from", "as"],
      "properties": { "type": { "const": "api.extract" }, "from": { "type": "string" }, "as": { "type": "string" } }
    },
    "apiAssert": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["assertion"],
      "properties": { "type": { "const": "api.assert" }, "assertion": { "type": "string" } }
    },
    "dbSelect": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["query"],
      "properties": {
        "type": { "const": "db.select" },
        "query": { "type": "string" },
        "params_ref": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1 }
      }
    },
    "cleanupApi": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["method", "path"],
      "properties": {
        "type": { "const": "cleanup.api" },
        "method": { "enum": ["POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string" },
        "input_ref": { "type": "string" }
      }
    },
    "cleanupWeb": {
      "allOf": [{ "$ref": "#/$defs/actionBase" }],
      "type": "object", "unevaluatedProperties": false,
      "required": ["locator"],
      "properties": { "type": { "const": "cleanup.web" }, "locator": { "type": "string" } }
    },
    "manifestCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "original", "steps"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "original": { "$ref": "#/$defs/original" },
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/action" } }
      }
    }
  }
}
