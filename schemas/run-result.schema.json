{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saitamasans.dev/schemas/run-result.schema.json",
  "title": "Run result protocol 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "run_id", "manifest_hash", "run_status", "started_at", "cases"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "run_id": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
    "manifest_hash": { "$ref": "#/$defs/sha256" },
    "contract_version": { "const": "1.0.0" },
    "package_sha256": { "$ref": "#/$defs/sha256" },
    "run_status": { "$ref": "#/$defs/runStatus" },
    "started_at": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
    "completed_at": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
    "cases": { "type": "array", "items": { "$ref": "#/$defs/caseResult" } },
    "defects": { "type": "array", "items": { "$ref": "#/$defs/rootDefect" } }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "contractFieldStatus": { "enum": ["executed", "blocked", "skipped", "failed"] },
    "runStatus": { "enum": ["planned", "running", "completed", "blocked", "executor_error", "infrastructure_error", "manual_required"] },
    "caseStatus": { "enum": ["未执行", "通过", "不通过", "待定"] },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion_id", "passed"],
      "properties": {
        "assertion_id": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
        "passed": { "type": "boolean" },
        "actual": { "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedJsonValue" },
        "expected": { "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedJsonValue" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "case_status", "run_status", "assertions", "evidence"],
      "properties": {
        "case_id": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
        "case_status": { "$ref": "#/$defs/caseStatus" },
        "run_status": { "$ref": "#/$defs/runStatus" },
        "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "execution_contract": { "$ref": "https://saitamasans.dev/schemas/run-manifest.schema.json#/$defs/manifestCase/properties/execution_contract" },
        "contract_field_status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["case_id", "source_case_id", "source_sheet", "title", "module", "priority", "execution_type", "automation_status", "isolation_scope", "flow_group", "start_state", "auth_profile", "setup", "actions", "assertions", "effects", "cleanup", "dependencies", "resource_locks", "evidence_policy", "unresolved"],
          "properties": {
            "case_id": { "$ref": "#/$defs/contractFieldStatus" },
            "source_case_id": { "$ref": "#/$defs/contractFieldStatus" },
            "source_sheet": { "$ref": "#/$defs/contractFieldStatus" },
            "title": { "$ref": "#/$defs/contractFieldStatus" },
            "module": { "$ref": "#/$defs/contractFieldStatus" },
            "priority": { "$ref": "#/$defs/contractFieldStatus" },
            "execution_type": { "$ref": "#/$defs/contractFieldStatus" },
            "automation_status": { "$ref": "#/$defs/contractFieldStatus" },
            "isolation_scope": { "$ref": "#/$defs/contractFieldStatus" },
            "flow_group": { "$ref": "#/$defs/contractFieldStatus" },
            "start_state": { "$ref": "#/$defs/contractFieldStatus" },
            "auth_profile": { "$ref": "#/$defs/contractFieldStatus" },
            "setup": { "$ref": "#/$defs/contractFieldStatus" },
            "actions": { "$ref": "#/$defs/contractFieldStatus" },
            "assertions": { "$ref": "#/$defs/contractFieldStatus" },
            "effects": { "$ref": "#/$defs/contractFieldStatus" },
            "cleanup": { "$ref": "#/$defs/contractFieldStatus" },
            "dependencies": { "$ref": "#/$defs/contractFieldStatus" },
            "resource_locks": { "$ref": "#/$defs/contractFieldStatus" },
            "evidence_policy": { "$ref": "#/$defs/contractFieldStatus" },
            "unresolved": { "$ref": "#/$defs/contractFieldStatus" }
          }
        }
      }
    },
    "rootDefect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defect_id", "root_cause_key", "case_ids", "evidence"],
      "properties": {
        "defect_id": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
        "root_cause_key": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] },
        "case_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "allOf": [{ "$ref": "https://saitamasans.dev/schemas/persisted-value.schema.json#/$defs/persistedString" }, { "type": "string", "minLength": 1 }] }
        },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      }
    }
  }
}
