{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saitamasans.dev/schemas/report.schema.json",
  "title": "Testing Skills versioned report",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "generated_at", "skill_invocation", "sheets"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "project": { "type": "string" },
    "generated_at": { "type": "string", "minLength": 1 },
    "skill_invocation": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary"],
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "roles": { "type": "string" },
            "confirmation": { "type": "string" }
          }
        }
      ]
    },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/testCaseSheet" },
          { "$ref": "#/$defs/otherSheet" }
        ]
      }
    }
  },
  "$defs": {
    "tenColumns": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        { "const": "用例 ID" },
        { "const": "所属模块" },
        { "const": "用例标题" },
        { "const": "验证功能点" },
        { "const": "前置条件" },
        { "const": "测试步骤" },
        { "const": "预期结果" },
        { "const": "优先级" },
        { "const": "执行结果" },
        { "const": "备注" }
      ],
      "items": false
    },
    "testCaseValues": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        {}, {}, {}, {}, {}, {}, {}, {},
        { "enum": ["未执行", "通过", "不通过", "待定"] },
        {}
      ],
      "items": false
    },
    "dividerValues": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        {}, {}, {}, {}, {}, {}, {}, {}, { "const": "-" }, {}
      ],
      "items": false
    },
    "testCaseRow": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["values"],
          "properties": {
            "divider": { "const": false },
            "values": { "$ref": "#/$defs/testCaseValues" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["divider", "values"],
          "properties": {
            "divider": { "const": true },
            "values": { "$ref": "#/$defs/dividerValues" }
          }
        }
      ]
    },
    "testCaseSheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "columns", "rows"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "const": "test_cases" },
        "columns": { "$ref": "#/$defs/tenColumns" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/testCaseRow" }
        }
      }
    },
    "otherSheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "columns", "rows"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "enum": ["overview", "supplementary"] },
        "columns": { "type": "array", "items": { "type": "string" } },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["values"],
            "properties": {
              "divider": { "type": "boolean" },
              "values": { "type": "array" }
            }
          }
        }
      }
    }
  }
}
