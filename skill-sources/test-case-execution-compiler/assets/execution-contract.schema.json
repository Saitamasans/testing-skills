{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saitamasans.github.io/testing-skills/schemas/execution-contract-1.0.0.json",
  "title": "Execution Contract 1.0.0",
  "type": "object",
  "required": ["contract_version", "cases"],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "cases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/case" } }
  },
  "additionalProperties": false,
  "$defs": {
    "case": {
      "type": "object",
      "required": ["case_id", "source_case_id", "source_sheet", "title", "module", "priority", "execution_type", "automation_status", "isolation_scope", "flow_group", "start_state", "auth_profile", "setup", "actions", "assertions", "effects", "cleanup", "dependencies", "resource_locks", "evidence_policy", "unresolved"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "source_case_id": { "type": "string", "minLength": 1 },
        "source_sheet": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "module": { "type": "string" },
        "priority": { "enum": ["P0", "P1", "P2"] },
        "execution_type": { "const": "web_ui" },
        "automation_status": { "enum": ["auto_ready", "needs_confirmation", "partial_manual", "manual_required", "not_suitable_for_automation"] },
        "isolation_scope": { "enum": ["case", "flow_group", "suite", "external_existing"] },
        "flow_group": { "type": ["string", "null"] },
        "start_state": { "type": "object" },
        "auth_profile": { "type": "object" },
        "setup": { "type": "array" },
        "actions": { "type": "array" },
        "assertions": { "type": "array" },
        "effects": { "type": "object" },
        "cleanup": { "type": "object" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "resource_locks": { "type": "array" },
        "evidence_policy": { "type": "object" },
        "unresolved": { "type": "array" }
      },
      "additionalProperties": false
    }
  }
}
