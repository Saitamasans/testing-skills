{
  "name": "@saitamasans/testing-runner",
  "version": "1.0.2",
  "type": "module",
  "bin": {
    "testing-runner": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-schemas.mjs && node scripts/copy-knowledge.mjs && node scripts/copy-renderer.mjs",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.0",
    "exceljs": "^4.4.0",
    "node-sql-parser": "^5.4.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "vendor",
    "examples"
  ]
}
